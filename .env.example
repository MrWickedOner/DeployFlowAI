# ====================================================================
# DeployFlow AI — Dual-Mode Environment Configuration
# ====================================================================
# Set DEPLOYFLOW_MODE to choose your deployment mode:
#   "cloud" — Supabase PostgreSQL + cloud AI API (OpenAI/Anthropic/Gemini)
#   "local" — SQLite via libsql + Ollama (self-hosted)
# Default: "cloud" (original SaaS mode)
# ====================================================================
DEPLOYFLOW_MODE=cloud

# --- Database Configuration ---
# Cloud Mode: Supabase (PostgreSQL)
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_KEY=your-service-role-key-here

# Local Mode: SQLite (via libsql)
# No env vars needed — SQLite file auto-creates at data/deployflow.db

# --- AI Provider Configuration ---
# For "cloud" mode:
AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (cloud mode, alternative)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# For "local" mode:
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Email Configuration ---
# Cloud mode: Resend / SendGrid
# RESEND_API_KEY=re_your-key-here
# SENDGRID_API_KEY=SG.your-key-here

# Local mode: User-provided SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# --- Stripe Billing ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Port & App ---
PORT=3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000