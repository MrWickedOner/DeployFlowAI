# DeployFlow AI Environment Variables
# Copy this file to .env or .env.local and fill in the values.

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional external scraper API keys (if using real Maps/Yelp searches in production)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
YELP_API_KEY=your_yelp_fusion_api_key
